###RUN THE FOLLOWING COMMANDS TO EXECUTE THIS MAKEFILE:
### make build -f makefile_main

SHELL := /bin/bash # Set shell

# Target directory
BUILD_TARGET_DIR = build

# The files to compile
INCLUDED_FILES = $(shell find src/* -type f -name "*cpp")

#The files to exclude
EXCLUDED_FILES = src/import/DEMO.cpp

# The files to compile
SRC = $(filter-out $(EXCLUDED_FILES), $(INCLUDED_FILES))

#The compiler to be used
COMPILER = g++ 

# Compiler options
COMPILER_FLAGS = -std=c++14 -pthread

# Executable name
OBJ_NAME = $(BUILD_TARGET_DIR)/movieRec++

.PHONY: prepare build debug

# Rules
prepare:
	mkdir -p $(BUILD_TARGET_DIR)

build : prepare
	# Building executable : ${OBJ_NAME}
	$(COMPILER) $(COMPILER_FLAGS) $(SRC) -o $(OBJ_NAME)
	

debug : prepare
	# Building executable : ${OBJ_NAME} with debug symbols.
	$(COMPILER) $(COMPILER_FLAGS) -g $(SRC) -o $(OBJ_NAME)
